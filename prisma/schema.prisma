generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  passwordHash        String
  name                String?
  isStudentDiscount   Boolean              @default(false)
  isLightParticipant  Boolean              @default(false)
  reviewCreditCents   Int                  @default(0)
  registrationStatus  RegistrationStatus   @default(APPROVED)
  registrationApprovedAt DateTime?
  registrationRejectedAt DateTime?
  birthDate           DateTime?
  heightCm            Float?
  motivation          String?
  image               String?
  emailVerified       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  challengeEnrollment ChallengeEnrollment?
  dailySubmissions    DailySubmission[]
  measurements        MeasurementEntry[]
  passwordResetTokens PasswordResetToken[]
  approvalsToReview   RegistrationApproval[] @relation("RegistrationApprovalReviewer")
  registrationApprovals RegistrationApproval[] @relation("RegistrationApprovalApplicant")
  sicknessReviewsToReview SicknessVerification[] @relation("SicknessVerificationReviewer")
  workoutReviewsToReview WorkoutReview[]   @relation("WorkoutReviewReviewer")
  invitesSent         AppInvite[]            @relation("AppInviteSender")
  acceptedInvite      AppInvite?             @relation("AppInviteAcceptedUser")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  expiresAt      DateTime
  usedAt         DateTime?
  requestedByIp  String?
  requestedByUa  String?
  emailDelivered Boolean   @default(false)
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ChallengeEnrollment {
  id                  String   @id @default(cuid())
  userId              String   @unique
  optedInAt           DateTime
  joinedChallengeDate String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailySubmission {
  id            String                @id @default(cuid())
  userId        String
  challengeDate String
  status        DailySubmissionStatus
  reviewStatus  WorkoutReviewStatus   @default(NOT_REQUIRED)
  verifiedPushupTotal Int?
  verifiedSitupTotal  Int?
  reviewedAt    DateTime?
  pushupSets    String
  situpSets     String
  notes         String?
  submittedAt   DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos        DailyVideo[]
  sicknessVerifications SicknessVerification[]
  workoutReviews WorkoutReview[]

  @@unique([userId, challengeDate])
  @@index([challengeDate])
  @@index([reviewStatus, challengeDate])
}

model DailyVideo {
  id                String          @id @default(cuid())
  dailySubmissionId String
  originalName      String
  storedName        String
  storedPath        String
  mimeType          String
  sizeBytes         Int
  orderIndex        Int
  createdAt         DateTime        @default(now())
  dailySubmission   DailySubmission @relation(fields: [dailySubmissionId], references: [id], onDelete: Cascade)

  @@index([dailySubmissionId])
}

model MeasurementEntry {
  id                   String   @id @default(cuid())
  userId               String
  measuredAt           DateTime
  weightKg             Float?
  waistCircumferenceCm Float?
  restingPulseBpm      Int?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, measuredAt])
}

model AppInvite {
  id             String    @id @default(cuid())
  email          String
  tokenHash      String    @unique
  invitedByUserId String
  acceptedUserId String?   @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())
  invitedBy      User      @relation("AppInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)
  acceptedUser   User?     @relation("AppInviteAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)

  @@index([email, expiresAt])
  @@index([invitedByUserId, createdAt])
}

model RegistrationApproval {
  id              String                     @id @default(cuid())
  applicantUserId String
  reviewerUserId  String
  decision        RegistrationApprovalDecision @default(PENDING)
  decidedAt       DateTime?
  createdAt       DateTime                   @default(now())
  applicant       User                       @relation("RegistrationApprovalApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  reviewer        User                       @relation("RegistrationApprovalReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([applicantUserId, reviewerUserId])
  @@index([reviewerUserId, decision])
  @@index([applicantUserId, decision])
}

model SicknessVerification {
  id                String                        @id @default(cuid())
  dailySubmissionId String
  reviewerUserId    String
  decision          RegistrationApprovalDecision  @default(PENDING)
  notes             String?
  decidedAt         DateTime?
  createdAt         DateTime                      @default(now())
  dailySubmission   DailySubmission               @relation(fields: [dailySubmissionId], references: [id], onDelete: Cascade)
  reviewer          User                          @relation("SicknessVerificationReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)

  @@unique([dailySubmissionId, reviewerUserId])
  @@index([dailySubmissionId, decision])
  @@index([reviewerUserId, decision])
}

model WorkoutReview {
  id                String              @id @default(cuid())
  dailySubmissionId String
  reviewerUserId    String
  stage             WorkoutReviewStage
  decision          WorkoutReviewDecision
  countedPushups    Int
  countedSitups     Int
  notes             String?
  basedOnReviewId   String?             @unique
  createdAt         DateTime            @default(now())
  decidedAt         DateTime            @default(now())
  dailySubmission   DailySubmission     @relation(fields: [dailySubmissionId], references: [id], onDelete: Cascade)
  reviewer          User                @relation("WorkoutReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  basedOnReview     WorkoutReview?      @relation("WorkoutReviewEscalation", fields: [basedOnReviewId], references: [id], onDelete: SetNull)
  escalationReview  WorkoutReview?      @relation("WorkoutReviewEscalation")

  @@index([dailySubmissionId, stage, createdAt])
  @@index([reviewerUserId, stage, createdAt])
}

enum RegistrationStatus {
  APPROVED
  PENDING
  REJECTED
}

enum RegistrationApprovalDecision {
  PENDING
  APPROVED
  REJECTED
}

enum DailySubmissionStatus {
  COMPLETED
  JOKER
  SLACK
  SICK_PENDING
  SICK_VERIFIED
}

enum WorkoutReviewStatus {
  NOT_REQUIRED
  PENDING
  ESCALATED
  APPROVED
  REVISION_REQUESTED
}

enum WorkoutReviewStage {
  PRIMARY
  ARBITRATION
}

enum WorkoutReviewDecision {
  APPROVE
  REDUCE
  REJECT
  ACCEPT_REVIEW
  REJECT_REVIEW
}
